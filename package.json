{
    "name": "personal-web",
    "version": "0.2.0",
    "description": "Personal web page to describe professional and personal projects, providing an environment to share deeper and detailed explanations.",
    "lint-staged": {
        "src/scripts/**/*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,md,html,json}": "prettier --cache --write",
        "src/**/*.astro": "prettier --cache --write",
        "src/pages/**/*.html": "prettier --cache --write",
        "src/styles/*.css": "prettier --cache --write"
    },
    "scripts": {
        "build-dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "lint": "eslint . --cache --fix && prettier . --write",
        "linting-staged": "npx lint-staged",
        "test": "echo \"Error: no test specified\" && exit 1",
        "prepare": "husky"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@commitlint/cli": "^20.4.1",
        "@commitlint/config-conventional": "^20.4.1",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/typography": "^0.5.19",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.6.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript-eslint": "^8.57.0"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.1",
        "@tailwindcss/cli": "^4.2.0",
        "@tailwindcss/vite": "^4.2.1",
        "astro": "^5.18.0",
        "flowbite": "^4.0.1",
        "pdfjs-dist": "^5.4.624",
        "simple-datatables": "^10.2.0",
        "tailwindcss": "^4.2.1"
    }
}
