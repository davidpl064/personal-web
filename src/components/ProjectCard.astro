---
import { getColorClasses, sanitizeDataTag } from '../scripts/badgeUtils.js'
import { toIsoYearMonth } from '../scripts/dateUtils.js'
import { projectThumbs } from '../scripts/imageRegistry.js'

const {
    title = '',
    'rel-path-project': relPathProjectPage = '',
    'image-key': imageKey = '',
    description = '',
    'data-tags': dataTags = '[]',
    'color-scheme': colorSchemes = '[]',
    'initial-date': initialDate = '',
    'end-date': endDate = '',
    status,
} = Astro.props

const imageProjectThumb = projectThumbs[imageKey]

// Parse JSON strings into an arrays
const dataTagsArray = JSON.parse(dataTags)

const colorSchemesRaw = Array.isArray(colorSchemes) ? colorSchemes : [colorSchemes]
const colorSchemesArray = JSON.parse(colorSchemesRaw)
const sanitizedDataTagsArray = sanitizeDataTag(dataTagsArray)

// Add the symbol "#" to each tag
const dataTagsArrayFormatted = sanitizedDataTagsArray.map((tag) => `#${tag}`).join(' ')

const colorClassesArray = colorSchemesArray.map((scheme) => {
    return getColorClasses(scheme)
})
---

<div
    class="card max-w-md rounded-lg border border-gray-200 bg-white shadow dark:border-gray-700 dark:bg-gray-800"
    data-tags={dataTagsArrayFormatted}
>
    <figure class="relative">
        <a href={relPathProjectPage}>
            <img class="rounded-t-lg" src={imageProjectThumb.src} alt="" />
        </a>
        <figcaption class="absolute bottom-2 px-4 text-lg text-white">
            <!-- Generate the badges for each tag dynamically -->
            {
                dataTagsArray.map((tag, index) => {
                    const { badgeColorClass, borderColorClass } = colorClassesArray[index]

                    return (
                        <span
                            class={`me-2 rounded border px-2.5 py-0.5 text-xs font-medium ${badgeColorClass} ${borderColorClass}`}
                        >
                            #{tag}
                        </span>
                    )
                })
            }
        </figcaption>
    </figure>
    <div class="p-2 pb-4">
        <a href={relPathProjectPage}>
            <h5 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                {title}
            </h5>
        </a>
        <div class="pointer-events-none mb-2 flex max-w-sm items-center space-x-1">
            <svg
                class="h-5 w-5 fill-current text-gray-400 dark:text-gray-100"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
            >
                <path
                    d="M6 5V4a1 1 0 1 1 2 0v1h3V4a1 1 0 1 1 2 0v1h3V4a1 1 0 1 1 2 0v1h1a2 2 0 0 1 2 2v2H3V7a2 2 0 0 1 2-2h1ZM3 19v-8h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Zm5-6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H8Z"
                >
                </path>
            </svg>
            <time
                class="text-sm leading-none font-normal text-gray-400 dark:text-gray-100"
                datetime={endDate
                    ? `${toIsoYearMonth(initialDate)}/${toIsoYearMonth(endDate)}`
                    : toIsoYearMonth(initialDate)}
                >{initialDate}
                {status === 'completed' && `- ${endDate}`}
                {status === 'ongoing' && '- Present'}
                {status === 'maintained' && '- Maintained'}</time
            >
        </div>
        <p class="mb-3 text-justify font-normal text-gray-700 dark:text-gray-400">
            {description}
        </p>
        <a
            href={relPathProjectPage}
            class="bottom-4 inline-flex items-center rounded-lg bg-blue-700 px-3 py-2 text-center text-sm font-medium text-white hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 focus:outline-none dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800"
        >
            Read more
            <svg
                class="ms-2 h-3.5 w-3.5 rtl:rotate-180"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 14 10"
            >
                <path
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M1 5h12m0 0L9 1m4 4L9 9"></path>
            </svg>
        </a>
    </div>
</div>
