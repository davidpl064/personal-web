---
import { Image } from 'astro:assets'

import { getColorClasses } from '../scripts/badgeUtils.js'
import { getColorStatus } from '../scripts/projectUtils.js'
import { toIsoYearMonth } from '../scripts/dateUtils.js'
import { projectThumbs } from '../scripts/imageRegistry.js'

const {
    title = '',
    'data-tags': dataTags = '[]',
    'color-schemes': colorSchemes = '[]',
    'image-key': imageKey = '',
    'initial-date': initialDate = '',
    'end-date': endDate = '',
    'dev-status': devStatus = '',
    'doc-status': docStatus = '',
    github,
} = Astro.props

const imageProjectThumb = projectThumbs[imageKey]

// Parse JSON strings into an arrays
const dataTagsArray = JSON.parse(dataTags)

const colorSchemesRaw = Array.isArray(colorSchemes) ? colorSchemes : [colorSchemes]
const colorSchemesArray = JSON.parse(colorSchemesRaw)

const colorClassesArray = colorSchemesArray.map((scheme) => {
    return getColorClasses(scheme)
})

// Get color classes from project's dev and documentation statuses
const devStatusColorClasses = getColorStatus(devStatus)
const docStatusColorClasses = getColorStatus(docStatus)
---

<div class="flex flex-col">
    <figure class="mx-auto max-w-(--breakpoint-xl)">
        <!-- Image container (handles overlay + title) -->
        <div class="relative overflow-hidden">
            <Image class="inset-0 w-full object-cover" src={imageProjectThumb} alt={title} />

            <!-- Overlay -->
            <div class="absolute inset-0 bg-black/50"></div>

            <!-- Centered Title -->
            <div class="absolute inset-0 flex items-center justify-center">
                <h1
                    class="text-center text-4xl font-semibold tracking-wide text-white uppercase md:text-6xl"
                >
                    {title}
                </h1>
            </div>
        </div>

        <!-- Bottom-left Tags -->
        <figcaption class="mt-3 space-y-2 px-4 text-gray-400 dark:text-gray-100">
            <div
                class="flex flex-wrap items-center text-sm [&>span:not(:last-child)]:after:mx-2 [&>span:not(:last-child)]:after:content-['|']"
            >
                <span class="inline-flex items-center">
                    <svg
                        class="me-1.5 h-5 w-5 fill-current"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M6 5V4a1 1 0 1 1 2 0v1h3V4a1 1 0 1 1 2 0v1h3V4a1 1 0 1 1 2 0v1h1a2 2 0 0 1 2 2v2H3V7a2 2 0 0 1 2-2h1ZM3 19v-8h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Zm5-6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H8Z"
                        >
                        </path>
                    </svg>
                    <time
                        class="text-sm leading-none font-normal text-gray-400 dark:text-gray-100"
                        datetime={endDate
                            ? `${toIsoYearMonth(initialDate)}/${toIsoYearMonth(endDate)}`
                            : toIsoYearMonth(initialDate)}
                        >{initialDate}
                        {devStatus === 'completed' && `- ${endDate}`}
                        {devStatus === 'ongoing' && '- Present'}
                        {devStatus === 'maintained' && '- Maintained'}</time
                    >
                </span>
                <span class="inline-flex items-center">
                    <span
                        data-tooltip-target="tooltip-dev-status"
                        class={`inline-flex items-center rounded border px-2 py-0.5 text-sm leading-none font-medium ${devStatusColorClasses}`}
                    >
                        <svg
                            class="me-1.5 h-5 w-5"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            fill="none"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M21 13v-2a1 1 0 0 0-1-1h-.757l-.707-1.707.535-.536a1 1 0 0 0 0-1.414l-1.414-1.414a1 1 0 0 0-1.414 0l-.536.535L14 4.757V4a1 1 0 0 0-1-1h-2a1 1 0 0 0-1 1v.757l-1.707.707-.536-.535a1 1 0 0 0-1.414 0L4.929 6.343a1 1 0 0 0 0 1.414l.536.536L4.757 10H4a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h.757l.707 1.707-.535.536a1 1 0 0 0 0 1.414l1.414 1.414a1 1 0 0 0 1.414 0l.536-.535 1.707.707V20a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-.757l1.707-.708.536.536a1 1 0 0 0 1.414 0l1.414-1.414a1 1 0 0 0 0-1.414l-.535-.536.707-1.707H20a1 1 0 0 0 1-1Z"
                            ></path>
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"></path>
                        </svg>
                        {devStatus}
                    </span>
                    <div
                        id="tooltip-dev-status"
                        role="tooltip"
                        class="tooltip invisible absolute z-10 inline-block rounded-base bg-dark px-3 py-2 text-sm font-medium text-white opacity-0 shadow-xs transition-opacity duration-300"
                    >
                        Development status of the project
                        <div class="tooltip-arrow" data-popper-arrow></div>
                    </div>
                </span>
                <span class="inline-flex items-center">
                    <span
                        data-tooltip-target="tooltip-doc-status"
                        class={`inline-flex items-center rounded border px-2 py-0.5 text-sm leading-none font-medium ${docStatusColorClasses}`}
                    >
                        <svg
                            class="me-1.5 h-5 w-5"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            fill="none"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 10V7.914a1 1 0 0 1 .293-.707l3.914-3.914A1 1 0 0 1 9.914 3H18a1 1 0 0 1 1 1v6M5 19v1a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-1M10 3v4a1 1 0 0 1-1 1H5m14 9.006h-.335a1.647 1.647 0 0 1-1.647-1.647v-1.706a1.647 1.647 0 0 1 1.647-1.647L19 12M5 12v5h1.375A1.626 1.626 0 0 0 8 15.375v-1.75A1.626 1.626 0 0 0 6.375 12H5Zm9 1.5v2a1.5 1.5 0 0 1-1.5 1.5v0a1.5 1.5 0 0 1-1.5-1.5v-2a1.5 1.5 0 0 1 1.5-1.5v0a1.5 1.5 0 0 1 1.5 1.5Z"
                            ></path>
                        </svg>
                        {docStatus}
                    </span>
                    <div
                        id="tooltip-doc-status"
                        role="tooltip"
                        class="tooltip invisible absolute z-10 inline-block rounded-base bg-dark px-3 py-2 text-sm font-medium text-white opacity-0 shadow-xs transition-opacity duration-300"
                    >
                        Documentation status of the project
                        <div class="tooltip-arrow" data-popper-arrow></div>
                    </div>
                </span>
            </div>
            <div class="flex items-center">
                <!-- Main tag icon -->
                <span class="text-sm">
                    <svg
                        class="me-1.5 h-5 w-5"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M18.045 3.007 12.31 3a1.965 1.965 0 0 0-1.4.585l-7.33 7.394a2 2 0 0 0 0 2.805l6.573 6.631a1.957 1.957 0 0 0 1.4.585 1.965 1.965 0 0 0 1.4-.585l7.409-7.477A2 2 0 0 0 21 11.479v-5.5a2.972 2.972 0 0 0-2.955-2.972Zm-2.452 6.438a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"
                        ></path>
                    </svg>
                </span>

                <ul class="flex flex-wrap gap-2">
                    <!-- Generate the badges for each tag dynamically -->
                    {
                        dataTagsArray.map((tag, index) => {
                            const { badgeColorClass, borderColorClass } = colorClassesArray[index]

                            return (
                                <span
                                    class={`me-2 rounded border px-2.5 py-0.5 text-xs font-medium ${badgeColorClass} ${borderColorClass}`}
                                >
                                    #{tag}
                                </span>
                            )
                        })
                    }
                </ul>
            </div>
            {
                github ? (
                    <a
                        href={github}
                        target="_blank"
                        class="flex items-center gap-2 transition-opacity duration-300 hover:opacity-75 md:text-2xl dark:hover:opacity-75"
                    >
                        {/* GitHub Icon */}
                        <i class="fab fa-sm fa-github" />

                        <span class="text-sm hover:underline">source code</span>
                    </a>
                ) : null
            }
        </figcaption>
    </figure>
</div>
