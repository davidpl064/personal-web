---
import { Image } from 'astro:assets'

const { title = '', 'image-hero': imageHero = '' } = Astro.props
---

<div class="flex flex-col max-w-(--breakpoint-xl) mx-auto">
    <figure class="mb-4 w-full relative overflow-hidden max-h-[60vh]">
        <Image class="inset-0 w-full object-cover" src={imageHero} alt={title} />

        <!-- Overlay -->
        <div class="absolute inset-0 bg-black/50"></div>

        <!-- Centered Title -->
        <div class="absolute inset-0 flex items-center justify-center">
            <h1
                class="text-4xl md:text-6xl font-semibold tracking-wide uppercase text-white text-center"
            >
                {title}
            </h1>
        </div>
    </figure>
    <div
        class="flex flex-wrap gap-2 pl-4 text-sm text-gray-400
            [&>span:not(:last-child)]:after:content-['|']
            [&>span:not(:last-child)]:after:mx-2"
    >
        <span>Updated: March 09, 2026</span>
        <!-- <span></span>
        <span></span> -->
    </div>
</div>
